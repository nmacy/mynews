datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String        @id @default(cuid())
  username       String        @unique
  email          String?
  hashedPassword String
  name           String?
  role           String        @default("user")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sessions       Session[]
  settings       UserSettings?
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  sources           String   @default("[]")
  featuredTags      String   @default("[]")
  disabledSourceIds String   @default("[]")
  customLibrary     String   @default("[]")
  sourceBarOrder    String   @default("[]")
  theme             String   @default("system")
  accent            String   @default("blue")
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServerApiKey {
  id           String   @id @default(cuid())
  provider     String   @unique
  encryptedKey String
  iv           String
  authTag      String
  model        String
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomTag {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  color     String
  parent    String?
  createdAt DateTime @default(now())
}

model CachedExtraction {
  id        String   @id @default(cuid())
  url       String   @unique
  title     String?
  content   String
  author    String?
  published String?
  image     String?
  ttr       Int?
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model ServerDefaultSources {
  id        String   @id @default(cuid())
  key       String   @unique
  sources   String   @default("[]")
  updatedAt DateTime @updatedAt
}

model ServerConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Article {
  id          String   @id
  url         String   @unique
  title       String
  description String
  content     String
  imageUrl    String?
  publishedAt DateTime
  sourceId    String
  sourceName  String
  categories  String   @default("[]")
  tags        String   @default("[]")
  priority    Int      @default(2)
  paywalled      Boolean  @default(false)
  aiTagged       Boolean  @default(false)
  relevanceScore Int      @default(5)
  extractable    Boolean?
  hasTimestamp Boolean  @default(true)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  expiresAt   DateTime

  @@index([sourceId])
  @@index([publishedAt])
  @@index([expiresAt])
  @@index([aiTagged])
  @@index([sourceId, expiresAt, publishedAt])
  @@index([expiresAt, publishedAt])
}
